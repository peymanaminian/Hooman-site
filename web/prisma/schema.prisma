// Prisma schema translated from database/schema.sql
// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Users & Auth ----------

model User {
  id           BigInt   @id @default(autoincrement())
  fullName     String   @map("full_name") @db.VarChar(150)
  email        String?  @unique @db.VarChar(150)
  phone        String?  @unique @db.VarChar(20)
  passwordHash String?  @map("password_hash") @db.VarChar(255)
  isGuest      Boolean  @default(false) @map("is_guest")
  status       String   @default("active") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")

  socialAccounts           SocialAccount[]
  addresses                Address[]
  reviews                  ProductReview[]
  views                    ProductView[]
  carts                    Cart[]
  orders                   Order[]
  walletTransactions       WalletTransaction[]
  loyaltyPoints            LoyaltyPoints?
  loyaltyPointTransactions LoyaltyPointTransaction[]

  @@map("users")
}

model SocialAccount {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt   @map("user_id")
  provider    String   @db.VarChar(30) // google, telegram, instagram
  providerUid String   @map("provider_uid") @db.VarChar(191)
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
  @@map("social_accounts")
}

model Address {
  id            BigInt  @id @default(autoincrement())
  userId        BigInt  @map("user_id")
  title         String? @db.VarChar(50)
  province      String  @db.VarChar(100)
  city          String  @db.VarChar(100)
  fullAddress   String  @map("full_address")
  postalCode    String? @map("postal_code") @db.VarChar(20)
  receiverName  String  @map("receiver_name") @db.VarChar(150)
  receiverPhone String  @map("receiver_phone") @db.VarChar(20)
  isDefault     Boolean @default(false) @map("is_default")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

model AdminRole {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50) // super_admin, product_manager, support, warehouse

  adminUsers AdminUser[]

  @@map("admin_roles")
}

model AdminUser {
  id           BigInt   @id @default(autoincrement())
  roleId       Int      @map("role_id")
  fullName     String   @map("full_name") @db.VarChar(150)
  email        String   @unique @db.VarChar(150)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  role AdminRole @relation(fields: [roleId], references: [id])

  @@map("admin_users")
}

// ---------- Categories & Products ----------

model Category {
  id        BigInt  @id @default(autoincrement())
  parentId  BigInt? @map("parent_id")
  name      String  @db.VarChar(150)
  slug      String  @unique @db.VarChar(160)
  iconUrl   String? @map("icon_url") @db.VarChar(255)
  sortOrder Int     @default(0) @map("sort_order")

  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")
  products Product[]

  @@map("categories")
}

model Product {
  id          BigInt   @id @default(autoincrement())
  categoryId  BigInt   @map("category_id")
  title       String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(280)
  description String?
  brand       String?  @db.VarChar(150)
  basePrice   Decimal  @map("base_price") @db.Decimal(14, 0)
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  category            Category                @relation(fields: [categoryId], references: [id])
  variants            ProductVariant[]
  images              ProductImage[]
  reviews             ProductReview[]
  views               ProductView[]
  recommendationsFrom ProductRecommendation[] @relation("ProductRecommendations")
  recommendationsTo   ProductRecommendation[] @relation("RelatedProductRecommendations")

  @@index([categoryId])
  @@map("products")
}

model ProductVariant {
  id             BigInt   @id @default(autoincrement())
  productId      BigInt   @map("product_id")
  sku            String   @unique @db.VarChar(100)
  color          String?  @db.VarChar(50)
  size           String?  @db.VarChar(50)
  price          Decimal  @db.Decimal(14, 0)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(14, 0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory  Inventory?
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("product_variants")
}

model ProductImage {
  id        BigInt @id @default(autoincrement())
  productId BigInt @map("product_id")
  url       String @db.VarChar(500)
  sortOrder Int    @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Inventory {
  variantId BigInt @id @map("variant_id")
  quantity  Int    @default(0)
  reserved  Int    @default(0)

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("inventory")
}

model ProductReview {
  id        BigInt   @id @default(autoincrement())
  productId BigInt   @map("product_id")
  userId    BigInt   @map("user_id")
  rating    Int      @db.SmallInt
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("product_reviews")
}

model ProductView {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt?  @map("user_id")
  productId BigInt   @map("product_id")
  viewedAt  DateTime @default(now()) @map("viewed_at")

  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("product_views")
}

// ---------- Cart & Orders ----------

model Cart {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt?  @map("user_id")
  sessionId String?  @map("session_id") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        BigInt @id @default(autoincrement())
  cartId    BigInt @map("cart_id")
  variantId BigInt @map("variant_id")
  quantity  Int    @default(1)

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("cart_items")
}

model Coupon {
  id            BigInt    @id @default(autoincrement())
  code          String    @unique @db.VarChar(50)
  discountType  String    @map("discount_type") @db.VarChar(20) // percent, fixed
  discountValue Decimal   @map("discount_value") @db.Decimal(14, 0)
  minOrderTotal Decimal   @default(0) @map("min_order_total") @db.Decimal(14, 0)
  maxUsage      Int?      @map("max_usage")
  usedCount     Int       @default(0) @map("used_count")
  expiresAt     DateTime? @map("expires_at")

  orders Order[]

  @@map("coupons")
}

model Order {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt   @map("user_id")
  addressId     BigInt   @map("address_id")
  couponId      BigInt?  @map("coupon_id")
  subtotal      Decimal  @db.Decimal(14, 0)
  discountTotal Decimal  @default(0) @map("discount_total") @db.Decimal(14, 0)
  shippingCost  Decimal  @default(0) @map("shipping_cost") @db.Decimal(14, 0)
  grandTotal    Decimal  @map("grand_total") @db.Decimal(14, 0)
  status        String   @default("pending") @db.VarChar(30)
  createdAt     DateTime @default(now()) @map("created_at")

  user                     User                      @relation(fields: [userId], references: [id])
  address                  Address                   @relation(fields: [addressId], references: [id])
  coupon                   Coupon?                   @relation(fields: [couponId], references: [id])
  items                    OrderItem[]
  payments                 Payment[]
  walletTransactions       WalletTransaction[]
  loyaltyPointTransactions LoyaltyPointTransaction[]

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id        BigInt  @id @default(autoincrement())
  orderId   BigInt  @map("order_id")
  variantId BigInt  @map("variant_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(14, 0)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Payment {
  id      BigInt    @id @default(autoincrement())
  orderId BigInt    @map("order_id")
  gateway String    @db.VarChar(30) // zarinpal, payping, wallet, cod
  amount  Decimal   @db.Decimal(14, 0)
  refId   String?   @map("ref_id") @db.VarChar(150)
  status  String    @default("pending") @db.VarChar(20)
  paidAt  DateTime? @map("paid_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model WalletTransaction {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  amount    Decimal  @db.Decimal(14, 0) // positive: charge, negative: spend
  type      String   @db.VarChar(30) // topup, order_payment, refund
  orderId   BigInt?  @map("order_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id])

  @@map("wallet_transactions")
}

// ---------- Loyalty Club ----------

model LoyaltyTier {
  id              Int     @id @default(autoincrement())
  name            String  @db.VarChar(50) // برنزی, نقره‌ای, طلایی
  minPoints       Int     @map("min_points")
  perkDescription String? @map("perk_description")

  members LoyaltyPoints[]

  @@map("loyalty_tiers")
}

model LoyaltyPoints {
  userId      BigInt @id @map("user_id")
  tierId      Int    @map("tier_id")
  totalPoints Int    @default(0) @map("total_points")

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier LoyaltyTier @relation(fields: [tierId], references: [id])

  @@map("loyalty_points")
}

model LoyaltyPointTransaction {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  orderId   BigInt?  @map("order_id")
  points    Int
  reason    String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id])

  @@map("loyalty_point_transactions")
}

// ---------- Product Recommendations ----------

model ProductRecommendation {
  id               BigInt  @id @default(autoincrement())
  productId        BigInt  @map("product_id")
  relatedProductId BigInt  @map("related_product_id")
  score            Decimal @default(0) @db.Decimal(6, 4)
  reason           String  @default("co_purchase") @db.VarChar(30) // co_purchase, similar_category, viewed_together

  product        Product @relation("ProductRecommendations", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("RelatedProductRecommendations", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedProductId])
  @@index([productId])
  @@map("product_recommendations")
}

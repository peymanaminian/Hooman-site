# Copy this file to .env (locally) or configure these as environment variables
# on your hosting provider. Never commit real secrets.

# Standard PostgreSQL connection string. Works with any Postgres provider
# (ParsPack, Neon, Supabase, RDS, self-hosted, ...).
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Random secret used to sign login session cookies. Generate one with:
#   openssl rand -hex 32
# Changing this value logs every user out.
SESSION_SECRET="change-me"

# Optional but recommended for self-hosted deployments with multiple
# instances/restarts: keeps Server Action references valid across them.
# Generate with: openssl rand -hex 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="change-me"

# ZarinPal payment gateway (added when payment integration is wired up).
# ZARINPAL_MERCHANT_ID="your-merchant-id"
